# Cloudflare Configuration for Photo Gallery
# Copy this file to .env and fill in your actual values

# Cloudflare Account ID
VITE_CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# Cloudflare R2 Access Key ID
VITE_CLOUDFLARE_ACCESS_KEY_ID=your-access-key-id-here

# Cloudflare R2 Secret Access Key
VITE_CLOUDFLARE_SECRET_ACCESS_KEY=your-secret-access-key-here

# Cloudflare R2 Bucket Name
VITE_CLOUDFLARE_R2_BUCKET_NAME=my-photo-gallery-bucket

# Cloudflare R2 Endpoint (usually https://your-account-id.r2.cloudflarestorage.com)
VITE_CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare Domain (your custom domain for serving images)
VITE_CLOUDFLARE_DOMAIN=images.yourdomain.com

# Optional: Enable debug logging for Cloudflare
# VITE_DEBUG_CLOUDFLARE=true

# WhatsApp Notification Configuration
# Choose ONE of the following options:

# Option 1: WhatsApp Business API (requires business account)
# WHATSAPP_TOKEN=your-whatsapp-business-api-token
# WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# Option 2: Twilio WhatsApp API (easier setup, no business account required)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=your-twilio-whatsapp-number

# Option 3: Email-to-WhatsApp via Zapier/IFTTT (simplest)
# EMAIL_WEBHOOK_URL=your-zapier-ifttt-webhook-url

# Admin contact information
ADMIN_PHONE_NUMBER=+5511999999999
VITE_ADMIN_PHONE_NUMBER=+5511999999999
# ADMIN_EMAIL=admin@yourdomain.com
