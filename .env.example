# Environment Configuration
VITE_APP_ENV=development

# Development Environment
VITE_SUPABASE_URL_DEV=your_supabase_dev_project_url
VITE_SUPABASE_ANON_KEY_DEV=your_supabase_dev_anon_key

# QA Environment
VITE_SUPABASE_URL_QA=your_supabase_qa_project_url
VITE_SUPABASE_ANON_KEY_QA=your_supabase_qa_anon_key

# UAT Environment
VITE_SUPABASE_URL_UAT=your_supabase_uat_project_url
VITE_SUPABASE_ANON_KEY_UAT=your_supabase_uat_anon_key

# Production Environment
VITE_SUPABASE_URL_PROD=your_supabase_prod_project_url
VITE_SUPABASE_ANON_KEY_PROD=your_supabase_prod_anon_key

# Fallback (used if environment-specific vars not found)
VITE_SUPABASE_URL=your_default_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_default_supabase_anon_key

# Weather API (Optional - will use mock data if not provided)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Lingo.dev Localization Compiler (Required for translation features)
GROQ_API_KEY=your_groq_api_key_here

# Stripe (Required for event ticket purchases)
STRIPE_SECRET_KEY=sk_live_or_test_your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_stripe_publishable_key

# Supabase Server-Side (Required for Netlify Functions)
# SUPABASE_ANON_KEY is used if set; otherwise falls back to VITE_SUPABASE_ANON_KEY
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key