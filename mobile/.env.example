# Supabase — same project as the web app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the deployed Netlify site (no trailing slash)
# Used to call Netlify Functions (generate-pkpass, lookup-event-ticket)
EXPO_PUBLIC_API_URL=https://your-site.netlify.app
